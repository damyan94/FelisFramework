{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "cd Build && cmake .. && cmake --build . -j4",
            "group": {
                "kind": "build",
                "cwd": "${workspaceFolder}/Build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}
